#!/usr/bin/env bun
/**
 * mission-advance — Model calls this script to advance pipeline state after eval.
 *
 * Usage:
 *   mission-advance <missionId> pass [mrUrl]
 *   mission-advance <missionId> fail "reason"
 */

const BOARD_PORT = process.env.REMI_BOARD_PORT ?? "8090";
const DB_PATH = `${process.env.HOME}/.remi/remi.db`;

const [missionId, verdict, reasonOrMrUrl] = process.argv.slice(2);

if (!missionId || !verdict) {
  console.error("Usage: mission-advance <missionId> pass|fail [reason]");
  process.exit(1);
}

const v = verdict.toLowerCase();
if (v !== "pass" && v !== "fail") {
  console.error(`Invalid verdict: "${verdict}". Use "pass" or "fail".`);
  process.exit(1);
}

// Direct DB update (same process as Remi, shared SQLite)
const { Database } = await import("bun:sqlite");
const db = new Database(DB_PATH);

const mission = db.query("SELECT id, status, current_step FROM missions WHERE id = ?").get(missionId) as any;
if (!mission) {
  console.error(`Mission ${missionId} not found`);
  process.exit(1);
}

// Only allow execution during eval step
if (mission.current_step !== "eval") {
  console.error(`❌ mission-advance can only run during eval step (current: ${mission.current_step})`);
  process.exit(1);
}

if (v === "pass") {
  const mrUrl = reasonOrMrUrl ?? null;
  if (mrUrl) {
    db.run("UPDATE missions SET status = 'in_review', mr_url = ?, mr_status = 'open', updated_at = datetime('now') WHERE id = ?", [mrUrl, missionId]);
  } else {
    db.run("UPDATE missions SET status = 'in_review', updated_at = datetime('now') WHERE id = ?", [missionId]);
  }
  console.log(`✅ Mission ${missionId} eval PASSED → in_review${mrUrl ? ` (MR: ${mrUrl})` : ""}`);
} else {
  // Check attempt count from skill_feedbacks
  const feedbacks = db.query(
    "SELECT COUNT(*) as cnt FROM skill_feedbacks WHERE mission_id = ? AND step = 'eval'"
  ).get(missionId) as any;
  const attempts = (feedbacks?.cnt ?? 0) + 1;

  if (attempts >= 3) {
    db.run("UPDATE missions SET status = 'blocked', updated_at = datetime('now') WHERE id = ?", [missionId]);
    console.log(`❌ Mission ${missionId} eval FAILED (attempt ${attempts}/3) → blocked`);
  } else {
    console.log(`❌ Mission ${missionId} eval FAILED (attempt ${attempts}/3) → re-execute`);
    // Record feedback
    const fbId = `fb_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
    db.run(
      "INSERT INTO skill_feedbacks (id, mission_id, step, skill_name, feedback_type, detail) VALUES (?, ?, 'eval', 'contract-eval', 'contract_fail', ?)",
      [fbId, missionId, reasonOrMrUrl ?? "eval failed"],
    );
    // Enqueue execute retry
    try {
      await fetch(`http://127.0.0.1:${BOARD_PORT}/api/internal/enqueue-intake`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ missionId, step: "execute", attempt: attempts, evalFailureInfo: reasonOrMrUrl }),
      });
      console.log(`🔄 Execute retry enqueued`);
    } catch (err) {
      console.error(`Failed to enqueue execute retry: ${err}`);
    }
  }
}

db.close();
