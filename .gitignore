# local on-disk copy (restorable from commit e259da82) against our Bun backend.
/multiremi/

# ---------------------------------------------------------------------------
# Remi runtime & secrets — never commit.
# Remi 运行时数据与敏感信息,严禁入库。
# ---------------------------------------------------------------------------

# Active config (use remi.toml.example as template)
remi.toml
!remi.toml.example

# Auth tokens — Remi runtime auth dir at repo ROOT only (leading slash).
# Must NOT recursively match frontend/src source dirs named auth/ (e.g.
# frontend/packages/views/auth, src/auth) — those are tracked source.
/auth/
*.tokens.json

# SQLite databases
*.db
*.db-shm
*.db-wal

# Runtime logs
log/
logs/

# Feishu image cache
lark_image/

# Per-user runtime directory (sessions, memory snapshots, etc.)
.remi/

# Personal soul prompt (use soul.md.example as template)
soul.md
!soul.md.example

# Vite frontend build output (not tracked)
web/frontend/dist/
