{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"],
      "@remi/feishu-channel": ["./packages/feishu-channel/src/index.ts"],
      "@remi/feishu-channel/*": ["./packages/feishu-channel/src/*"],
      "@remi/acp-provider": ["./packages/acp-provider/src/index.ts"],
      "@remi/acp-provider/*": ["./packages/acp-provider/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
