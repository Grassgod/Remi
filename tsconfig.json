{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "paths": {
      "@remi/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "@remi/plugin-sdk/*": ["./packages/plugin-sdk/src/*"],
      "@multiremi/contracts": ["./packages/contracts/src/index.ts"],
      "@multiremi/contracts/*": ["./packages/contracts/src/*"],
      "@shared/contracts/*": ["./packages/contracts/src/*"],
      "@shared/*": ["./packages/shared/src/*"],
      "@acp/*": ["./packages/acp/src/*"],
      "@memory/*": ["./packages/memory/src/*"],
      "@queue/*": ["./packages/queue/src/*"],
      "@connectors/*": ["./packages/connectors/src/*"],
      "@auth/*": ["./packages/auth/src/*"],
      "@daemon/*": ["./packages/daemon/src/*"],
      "@remi/*": ["./packages/remi/src/*"],
      "@multiremi/*": ["./packages/server/src/*"]
    }
  },
  "include": ["apps/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
