{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./src/*"],
      "@remi/plugin-sdk": ["./packages/plugin-sdk/src/index.ts"],
      "@remi/plugin-sdk/*": ["./packages/plugin-sdk/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@acp/*": ["./src/acp/*"],
      "@memory/*": ["./src/memory/*"],
      "@queue/*": ["./src/queue/*"],
      "@connectors/*": ["./src/connectors/*"],
      "@auth/*": ["./src/auth/*"],
      "@daemon/*": ["./src/daemon/*"],
      "@remi/*": ["./src/remi/*"],
      "@multiremi/*": ["./src/multiremi/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
