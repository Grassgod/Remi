#!/usr/bin/env node
// CommonJS (not ESM): this file ships to /usr/local/bin without a `.mjs`
// extension or a sibling package.json, so Node <20 would parse it as CJS and
// reject `import`. Using require keeps it runnable on Node 18+ and newer alike.
const { spawn, spawnSync } = require("node:child_process");
const { createHash } = require("node:crypto");
const {
  cpSync,
  existsSync,
  mkdirSync,
  readFileSync,
  realpathSync,
  renameSync,
  rmSync,
  statSync,
  writeFileSync,
} = require("node:fs");
const { createRequire } = require("node:module");
const { homedir } = require("node:os");
const { basename, dirname, join, resolve } = require("node:path");

const PACKAGE_NAMES = [
  "@zed-industries/claude-agent-acp",
  "@agentclientprotocol/claude-agent-acp",
];
const SDK_PACKAGE_NAME = "@anthropic-ai/claude-agent-sdk";
const MIN_CLAUDE_CODE_VERSION = "2.1.120";
const PATCH_VERSION = "ask-bridge-v2";

main().catch((err) => {
  const message = err instanceof Error ? err.message : String(err);
  console.error(`[remi-claude-agent-acp] ${message}`);
  process.exit(1);
});

async function main() {
  const prepared = preparePatchedPackage();
  const patchedRoot = prepared.root;
  const patchedIndex = join(patchedRoot, "dist", "index.js");

  if (process.argv.includes("--print-patched-agent")) {
    console.log(patchedIndex);
    return;
  }
  if (process.argv.includes("--verify-patch")) {
    verifyPreparedPackage(patchedRoot, prepared.runtime);
    console.log(`ok ${patchedIndex}`);
    return;
  }

  const args = process.argv.slice(2);
  const env = { ...process.env };
  if (prepared.runtime.claudeCodeExecutable) {
    env.CLAUDE_CODE_EXECUTABLE = prepared.runtime.claudeCodeExecutable;
  }
  const child = spawn(process.execPath, [patchedIndex, ...args], {
    cwd: process.cwd(),
    env,
    stdio: "inherit",
  });

  const signals = process.platform === "win32"
    ? ["SIGINT", "SIGTERM"]
    : ["SIGINT", "SIGTERM", "SIGHUP"];
  for (const signal of signals) {
    process.on(signal, () => {
      if (!child.killed) child.kill(signal);
    });
  }

  child.on("error", (err) => {
    console.error(`[remi-claude-agent-acp] ${err.message}`);
    process.exit(1);
  });
  child.on("exit", (code, signal) => {
    if (signal && process.platform !== "win32") {
      process.removeAllListeners(signal);
      process.kill(process.pid, signal);
    } else {
      process.exit(code ?? 1);
    }
  });
}

function preparePatchedPackage() {
  const upstreamRoot = findUpstreamPackageRoot();
  const pkg = readPackageJson(upstreamRoot);
  const acpAgentPath = join(upstreamRoot, "dist", "acp-agent.js");
  const upstreamHash = hashFile(acpAgentPath).slice(0, 12);
  const runtime = resolveClaudeRuntime(upstreamRoot);
  const runtimeCacheKey = runtime.cacheKey;
  const cacheRoot = process.env.REMI_CLAUDE_AGENT_ACP_CACHE
    ?? join(process.env.REMI_HOME ?? join(homedir(), ".remi"), "cache", "claude-agent-acp-remi");
  const dest = join(
    cacheRoot,
    safeCacheSegment(pkg.name),
    `${pkg.version}-${upstreamHash}-${PATCH_VERSION}-${safeCacheSegment(runtimeCacheKey)}`,
    "package",
  );

  if (existsSync(join(dest, "dist", "index.js"))) {
    verifyPreparedPackage(dest, runtime);
    return { root: dest, runtime };
  }

  const tmp = `${dest}.tmp-${process.pid}-${Date.now()}`;
  rmSync(tmp, { recursive: true, force: true });
  mkdirSync(dirname(dest), { recursive: true });
  cpSync(upstreamRoot, tmp, { recursive: true });
  patchAcpAgent(join(tmp, "dist", "acp-agent.js"));
  if (existsSync(join(dest, "dist", "index.js"))) {
    verifyPreparedPackage(dest, runtime);
    rmSync(tmp, { recursive: true, force: true });
    return { root: dest, runtime };
  }
  try {
    renameSync(tmp, dest);
  } catch (err) {
    if (existsSync(join(dest, "dist", "index.js"))) {
      verifyPreparedPackage(dest, runtime);
      rmSync(tmp, { recursive: true, force: true });
      return { root: dest, runtime };
    }
    throw err;
  }
  verifyPreparedPackage(dest, runtime);
  return { root: dest, runtime };
}

function findUpstreamPackageRoot() {
  const candidates = [
    process.env.REMI_CLAUDE_AGENT_ACP_PACKAGE,
    process.env.REMI_CLAUDE_AGENT_ACP_DIR,
    process.env.REMI_CLAUDE_AGENT_ACP_PATH,
  ];

  const localPackage = resolvePackageWithRequire(PACKAGE_NAMES);
  if (localPackage) candidates.push(localPackage);

  const pathBinary = resolveCommand("claude-agent-acp");
  if (pathBinary) candidates.push(pathBinary);

  // remi-provisioned location (`remi` installs the bridge here when missing).
  const remiHome = process.env.REMI_HOME || join(homedir(), ".remi");
  candidates.push(
    join(remiHome, "acp", "node_modules", "@zed-industries", "claude-agent-acp"),
    join(remiHome, "acp", "node_modules", "@agentclientprotocol", "claude-agent-acp"),
  );

  candidates.push(
    join(homedir(), ".npm-global", "lib", "node_modules", "@zed-industries", "claude-agent-acp"),
    join(homedir(), ".npm-global", "lib", "node_modules", "@agentclientprotocol", "claude-agent-acp"),
    join("/usr/local", "lib", "node_modules", "@zed-industries", "claude-agent-acp"),
    join("/usr/local", "lib", "node_modules", "@agentclientprotocol", "claude-agent-acp"),
    join("/opt/homebrew", "lib", "node_modules", "@zed-industries", "claude-agent-acp"),
    join("/opt/homebrew", "lib", "node_modules", "@agentclientprotocol", "claude-agent-acp"),
  );

  const npmRoot = npmGlobalRoot();
  if (npmRoot) {
    candidates.push(join(npmRoot, "@zed-industries", "claude-agent-acp"));
    candidates.push(join(npmRoot, "@agentclientprotocol", "claude-agent-acp"));
  }

  for (const candidate of candidates) {
    const root = normalizePackageRoot(candidate);
    if (root) return root;
  }

  throw new Error(
    `Could not locate claude-agent-acp (${PACKAGE_NAMES.join(" or ")}). Install claude-agent-acp or set REMI_CLAUDE_AGENT_ACP_DIR to its package directory.`,
  );
}

function normalizePackageRoot(candidate) {
  if (!candidate) return null;
  let current;
  try {
    current = realpathSync(resolve(candidate));
  } catch {
    return null;
  }

  try {
    const stat = statSync(current);
    if (stat.isFile()) current = dirname(current);
  } catch {
    return null;
  }

  if (basename(current) === "dist") current = dirname(current);

  for (let i = 0; i < 8; i++) {
    const packageJsonPath = join(current, "package.json");
    if (existsSync(packageJsonPath)) {
      try {
        const pkg = JSON.parse(readFileSync(packageJsonPath, "utf-8"));
        if (PACKAGE_NAMES.includes(pkg.name) && existsSync(join(current, "dist", "index.js"))) {
          return current;
        }
      } catch {}
    }
    const parent = dirname(current);
    if (parent === current) break;
    current = parent;
  }

  return null;
}

function resolvePackageWithRequire(packageNames) {
  const require = createRequire(__filename);
  const names = Array.isArray(packageNames) ? packageNames : [packageNames];
  for (const packageName of names) {
    try {
      return require.resolve(`${packageName}/package.json`);
    } catch {}
  }
  return null;
}

function resolveCommand(command) {
  const result = spawnSync("bash", ["-lc", `command -v ${command}`], {
    encoding: "utf-8",
    stdio: ["ignore", "pipe", "ignore"],
    timeout: 5000,
  });
  const value = result.stdout?.trim();
  return value || null;
}

function npmGlobalRoot() {
  const result = spawnSync("npm", ["root", "-g"], {
    encoding: "utf-8",
    stdio: ["ignore", "pipe", "ignore"],
    timeout: 5000,
  });
  if (result.status !== 0) return null;
  return result.stdout?.trim() || null;
}

function readPackageJson(root) {
  return JSON.parse(readFileSync(join(root, "package.json"), "utf-8"));
}

function resolveClaudeRuntime(upstreamRoot) {
  const bundledRoot = join(upstreamRoot, "node_modules", "@anthropic-ai", "claude-agent-sdk");
  const bundled = readClaudeAgentSdkInfo(bundledRoot);
  if (bundled && isVersionAtLeast(bundled.claudeCodeVersion, MIN_CLAUDE_CODE_VERSION)) {
    return {
      source: "bundled-sdk",
      cacheKey: `bundled-sdk-${bundled.version}-${bundled.claudeCodeVersion}`,
      claudeCodeExecutable: null,
      version: bundled.claudeCodeVersion,
    };
  }

  const executable = findCompatibleClaudeCodeExecutable();
  if (executable) {
    return {
      source: "claude-cli",
      cacheKey: `claude-cli-${executable.version}-${hashString(executable.path).slice(0, 8)}`,
      claudeCodeExecutable: executable.path,
      version: executable.version,
    };
  }

  const bundledVersion = bundled
    ? `${SDK_PACKAGE_NAME}@${bundled.version} / Claude Code ${bundled.claudeCodeVersion}`
    : "missing bundled SDK";
  throw new Error(
    `Claude ACP bundled SDK is too old (${bundledVersion}) and no compatible Claude Code executable was found. Upgrade Claude Code or set REMI_CLAUDE_CODE_EXECUTABLE/CLAUDE_CODE_EXECUTABLE; minimum Claude Code version is ${MIN_CLAUDE_CODE_VERSION}.`,
  );
}

function findCompatibleClaudeCodeExecutable() {
  const candidates = [
    process.env.REMI_CLAUDE_CODE_EXECUTABLE,
    process.env.CLAUDE_CODE_EXECUTABLE,
  ];

  const pathBinary = resolveCommand("claude");
  if (pathBinary) candidates.push(pathBinary);

  candidates.push(
    join(homedir(), ".local", "bin", "claude"),
    join(homedir(), ".npm-global", "bin", "claude"),
    join("/usr/local", "bin", "claude"),
    join("/opt/homebrew", "bin", "claude"),
  );

  const npmRoot = npmGlobalRoot();
  if (npmRoot) candidates.push(join(npmRoot, "@anthropic-ai", "claude-code", "bin", "claude"));

  for (const candidate of candidates) {
    const executable = normalizeExecutable(candidate);
    if (!executable) continue;
    const version = readClaudeCodeVersion(executable);
    if (version && isVersionAtLeast(version, MIN_CLAUDE_CODE_VERSION)) {
      return { path: executable, version };
    }
  }

  return null;
}

function normalizeExecutable(candidate) {
  if (!candidate) return null;
  try {
    const path = realpathSync(resolve(candidate));
    if (statSync(path).isFile()) return path;
  } catch {
    return null;
  }
  return null;
}

function readClaudeCodeVersion(executable) {
  const result = spawnSync(executable, ["--version"], {
    encoding: "utf-8",
    stdio: ["ignore", "pipe", "pipe"],
    timeout: 5000,
  });
  if (result.status !== 0) return null;
  const output = `${result.stdout ?? ""}\n${result.stderr ?? ""}`;
  const match = output.match(/(\d+\.\d+\.\d+)/);
  return match?.[1] ?? null;
}

function readClaudeAgentSdkInfo(root) {
  const packageJsonPath = join(root, "package.json");
  if (!existsSync(packageJsonPath)) return null;
  try {
    const pkg = JSON.parse(readFileSync(packageJsonPath, "utf-8"));
    if (pkg.name !== SDK_PACKAGE_NAME) return null;
    return {
      root,
      version: String(pkg.version ?? "0.0.0"),
      claudeCodeVersion: String(pkg.claudeCodeVersion ?? pkg.version ?? "0.0.0"),
    };
  } catch {
    return null;
  }
}

function hashFile(path) {
  return createHash("sha256").update(readFileSync(path)).digest("hex");
}

function hashString(value) {
  return createHash("sha256").update(String(value)).digest("hex");
}

function safeCacheSegment(value) {
  return String(value).replace(/[^a-zA-Z0-9._-]+/g, "_").replace(/^_+|_+$/g, "") || "claude-agent-acp";
}

function isVersionAtLeast(actual, minimum) {
  const actualParts = parseVersion(actual);
  const minimumParts = parseVersion(minimum);
  for (let i = 0; i < 3; i++) {
    if (actualParts[i] > minimumParts[i]) return true;
    if (actualParts[i] < minimumParts[i]) return false;
  }
  return true;
}

function parseVersion(version) {
  return String(version)
    .split(".")
    .slice(0, 3)
    .map((part) => {
      const value = parseInt(part.replace(/[^0-9].*$/, ""), 10);
      return Number.isFinite(value) ? value : 0;
    })
    .concat([0, 0, 0])
    .slice(0, 3);
}

// claude-agent-acp >= 0.44 surfaces the built-in AskUserQuestion tool as an ACP
// form elicitation natively (see handleAskUserQuestion in the upstream
// acp-agent), which is exactly what this wrapper used to patch in. When that
// native bridge is present there is nothing to patch.
function buildHasNativeAskBridge(source) {
  return source.includes("handleAskUserQuestion")
    && source.includes('toolName === "AskUserQuestion"');
}

function patchAcpAgent(path) {
  let source = readFileSync(path, "utf-8");

  // Upstream already bridges AskUserQuestion → ACP elicitation; no patch needed.
  if (buildHasNativeAskBridge(source)) {
    verifyPatchedAgent(path);
    return;
  }

  // Legacy builds: drop AskUserQuestion from the disallow list and forward the
  // elicitation answer back to the tool's call() via updatedInput.
  const disallowedMarker = 'const disallowedTools = ["AskUserQuestion"];';
  if (source.includes(disallowedMarker)) {
    source = source.replace(disallowedMarker, "const disallowedTools = [];");
  } else if (!source.includes("const disallowedTools = [];")) {
    throw new Error("Unsupported claude-agent-acp build: AskUserQuestion disallow marker was not found.");
  }

  const permissionStart = source.indexOf(
    '            const response = await this.client.requestPermission({\n                options: [\n                    {\n                        kind: "allow_always",',
  );
  if (permissionStart === -1) {
    throw new Error("Unsupported claude-agent-acp build: generic permission block was not found.");
  }
  const permissionEnd = source.indexOf(
    '            else {\n                return {\n                    behavior: "deny",',
    permissionStart,
  );
  if (permissionEnd === -1) {
    throw new Error("Unsupported claude-agent-acp build: generic permission block end was not found.");
  }

  const beforeBlock = source.slice(0, permissionStart);
  const block = source.slice(permissionStart, permissionEnd);
  const afterBlock = source.slice(permissionEnd);
  const patchedBlock = block.replaceAll(
    "updatedInput: toolInput,",
    "updatedInput: response.outcome?.updatedInput ?? toolInput,",
  );
  if (
    patchedBlock === block &&
    !block.includes("response.outcome?.updatedInput ?? toolInput")
  ) {
    throw new Error("Unsupported claude-agent-acp build: updatedInput return point was not found.");
  }

  source = `${beforeBlock}${patchedBlock}${afterBlock}`;
  writeFileSync(path, source, "utf-8");
  verifyPatchedAgent(path);
}

function verifyPatchedAgent(path) {
  const source = readFileSync(path, "utf-8");
  // Newer builds bridge AskUserQuestion natively — accept as-is.
  if (buildHasNativeAskBridge(source)) return;
  if (!source.includes("const disallowedTools = [];")) {
    throw new Error("Patched claude-agent-acp still blocks AskUserQuestion.");
  }
  if (!source.includes("response.outcome?.updatedInput ?? toolInput")) {
    throw new Error("Patched claude-agent-acp cannot forward Remi AskUserQuestion answers.");
  }
}

function verifyPreparedPackage(root, runtime) {
  verifyPatchedAgent(join(root, "dist", "acp-agent.js"));
  const sdk = readClaudeAgentSdkInfo(join(root, "node_modules", "@anthropic-ai", "claude-agent-sdk"));
  if (sdk && isVersionAtLeast(sdk.claudeCodeVersion, MIN_CLAUDE_CODE_VERSION)) return;
  if (runtime?.claudeCodeExecutable && isVersionAtLeast(runtime.version, MIN_CLAUDE_CODE_VERSION)) return;

  const version = sdk ? `${sdk.version} / Claude Code ${sdk.claudeCodeVersion}` : "missing";
  throw new Error(
    `Prepared claude-agent-acp package has incompatible ${SDK_PACKAGE_NAME}: ${version}, and no compatible Claude Code executable was selected. Minimum Claude Code version is ${MIN_CLAUDE_CODE_VERSION}.`,
  );
}
