# ---------------------------------------------------------------------------
# [proxy] — HTTP proxy used for outbound requests (LLM APIs, Feishu, etc.).
# 出站请求使用的 HTTP 代理(LLM API、飞书等)。
# Leave empty if you don't need a proxy. `no_proxy` is a comma-separated
# list of hosts/CIDRs that bypass the proxy.
# 如不需要代理可留空。`no_proxy` 是逗号分隔的绕过代理的主机/网段列表。
# ---------------------------------------------------------------------------
[proxy]
http = "http://127.0.0.1:7890"
no_proxy = "localhost,127.0.0.1,::1"

# ---------------------------------------------------------------------------
# [tracing] — LangSmith tracing (optional).
# LangSmith 追踪(可选)。
# Sign up at https://smith.langchain.com to capture LLM traces.
# 在 https://smith.langchain.com 注册以采集 LLM 调用链路。
# ---------------------------------------------------------------------------
[tracing]
langsmith_api_key = "your-langsmith-api-key-here"
langsmith_project = "Remi"

# ---------------------------------------------------------------------------
# [bytedance_sso] — ByteDance internal SSO (optional, for ByteDance employees).
# 字节跳动内部 SSO(可选,仅对字节员工有效)。
# Used by token_sync below to refresh bytedcli credentials.
# 配合下方 token_sync 用于刷新 bytedcli 凭证。
# ---------------------------------------------------------------------------
[bytedance_sso]
client_id = "your-bytedance-sso-client-id-here"

# ---------------------------------------------------------------------------
# [[token_sync]] — Mirror auth tokens from Remi's auth store to other tools.
# 将 Remi auth store 中的认证 token 镜像到其他工具的存储位置。
# `source`: glob/path inside Remi's auth store.
# `target`: file path the consuming tool reads (use `~` for $HOME).
# `format`: "mirror" | "bytedcli_token" | "json_kv".
# `source`: Remi auth store 内的路径或 glob。
# `target`: 目标工具读取的文件路径(支持 `~`)。
# `format`: 输出格式,可选 mirror / bytedcli_token / json_kv。
# ---------------------------------------------------------------------------
[[token_sync]]
name = "lark-mcp-server"
source = "feishu/*"
target = "~/.lark_auth/tokens.json"
format = "mirror"

# Optional ByteDance-specific token sync (remove if not applicable).
# 字节专用 token 同步(如不适用请删除)。
# [[token_sync]]
# name = "bytedcli-sso"
# source = "bytedance-sso/access"
# target = "~/.local/share/bytedcli/data/token.json"
# format = "bytedcli_token"
#
# [[token_sync]]
# name = "bytedcli-jwt"
# source = "bytedance-sso/jwt"
# target = "~/.local/share/bytedcli/data/jwt_override.json"
# format = "json_kv"
# key = "token"

# ---------------------------------------------------------------------------
# [[cron.jobs]] — Scheduled jobs (cron expression or interval).
# 定时任务(支持 cron 表达式或 every 间隔)。
# `handler`: builtin:* | agent:<name> | skill:run | cli-ingest
# `cron`: 5-field cron expression (UTC by default).
# `every`: shorthand for fixed interval (e.g. "300s").
# `handler_config.delivery.pushTargets`: open_id list to push results to.
# `handler`: 任务处理器类型。
# `cron`: 5 字段 cron 表达式(默认 UTC 时区)。
# `every`: 固定间隔的简写(如 "300s")。
# `handler_config.delivery.pushTargets`: 推送结果的 open_id 列表。
# ---------------------------------------------------------------------------
[[cron.jobs]]
id = "builtin:heartbeat"
name = "Heartbeat"
handler = "builtin:heartbeat"
every = "300s"

[[cron.jobs]]
id = "agent:memory-audit"
name = "Memory Audit Agent"
handler = "agent:memory-audit"
cron = "0 3 * * *"

[cron.jobs.handler_config]
connectorName = "feishu"
pushTargets = [ "your-feishu-open-id-here" ]

[[cron.jobs]]
id = "agent:wiki-curate"
name = "Wiki Curate Agent"
handler = "agent:wiki-curate"
cron = "45 3 * * *"

[cron.jobs.handler_config]
connectorName = "feishu"
pushTargets = [ "your-feishu-open-id-here" ]

[[cron.jobs]]
id = "cli-ingest"
name = "Claude Code CLI Ingestion"
handler = "cli-ingest"
cron = "17 * * * *"

[[cron.jobs]]
id = "skill:ai-daily-briefing"
name = "AI Daily Briefing"
handler = "skill:run"
cron = "15 10 * * *"

[cron.jobs.handler_config]
skillName = "ai-daily-briefing"
outputDir = "~/.remi/tasks/briefing"

[cron.jobs.handler_config.delivery]
connectorName = "feishu"
pushTargets = [ "your-feishu-open-id-here" ]
maxPushLength = 4000

[[cron.jobs]]
id = "skill:memory-research"
name = "Memory Research"
handler = "skill:run"
cron = "45 10 * * *"

[cron.jobs.handler_config]
skillName = "memory-research"
outputDir = "~/.remi/tasks/memory-research"

[cron.jobs.handler_config.delivery]
connectorName = "feishu"
pushTargets = [ "your-feishu-open-id-here" ]
maxPushLength = 4000

[[cron.jobs]]
id = "skill:repo-update"
name = "Repo Update"
handler = "skill:run"
cron = "0 4 * * *"

[cron.jobs.handler_config]
skillName = "repo-update"
outputDir = "~/.remi/tasks/repo-updates"

[cron.jobs.handler_config.delivery]
connectorName = "feishu"
pushTargets = [ "your-feishu-open-id-here" ]
maxPushLength = 4000

# ---------------------------------------------------------------------------
# [google] — Google Gemini API (used by `/image` skill via Nano Banana).
# Google Gemini API(由 `/image` 技能通过 Nano Banana 使用)。
# Get a key at https://aistudio.google.com/apikey.
# 在 https://aistudio.google.com/apikey 申请 API key。
# ---------------------------------------------------------------------------
[google]
api_key = "your-google-api-key-here"
model = "gemini-3.1-flash-image-preview"

# ---------------------------------------------------------------------------
# [embedding] — Embedding provider for memory semantic search.
# 记忆语义搜索的 embedding 服务。
# `provider`: "voyage" | "openai" | ...
# Get a Voyage AI key at https://www.voyageai.com.
# `provider` 可选 voyage / openai 等;
# 在 https://www.voyageai.com 申请 Voyage AI key。
# ---------------------------------------------------------------------------
[embedding]
provider = "voyage"
api_key = "your-embedding-api-key-here"
model = "voyage-3.5-lite"
