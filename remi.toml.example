# Remi Configuration Example
# Copy this file to `remi.toml` (or `~/.remi/remi.toml`) and fill in your own values.
# 复制此文件为 `remi.toml`(或 `~/.remi/remi.toml`)，并填入你自己的值。
#
# Search order (优先级): ./remi.toml > ~/.remi/remi.toml > defaults
# Sensitive fields (api_key, app_secret, client_id, etc.) MUST never be committed.
# 敏感字段(api_key、app_secret、client_id 等)严禁提交到代码仓库。

# ---------------------------------------------------------------------------
# [provider] — Default AI backend.
# 默认 AI 后端配置。
# Remi defaults to ClaudeCLIProvider (uses your local Claude Code subscription,
# no API key needed). Uncomment below to use a remote OpenAI-compatible endpoint.
# Remi 默认使用 ClaudeCLIProvider(基于本地 Claude Code 订阅，无需 API key)。
# 如需使用远程 OpenAI 兼容端点，取消下方注释。
# ---------------------------------------------------------------------------
[provider]
# name = "acp"              # ACP mode — auto-registers both claude and codex siblings for /switch
# name = "acp:claude"       # ACP Claude via claude-agent-acp (also registers codex sibling)
# name = "acp:codex"        # ACP Codex via codex-acp (also registers claude sibling)
# Install codex-acp with: npm install -g @agentclientprotocol/codex-acp
# Or set REMI_CODEX_AGENT_ACP_EXECUTABLE=/absolute/path/to/codex-acp
# executable = "/path/to/codex-acp"
# model = "claude-opus-4-7"
# api_key = "your-provider-api-key-here"
# base_url = "http://localhost:3000"

# ---------------------------------------------------------------------------
# [feishu] — Feishu/Lark bot connector.
# 飞书/Lark 机器人连接器配置。
# Create an app at https://open.feishu.cn (or https://open.larksuite.com).
# 在 https://open.feishu.cn 创建应用获取 app_id 和 app_secret。
# `domain`: "feishu" for China cloud, "lark" for international.
# `domain`: 国内版填 "feishu"，国际版填 "lark"。
# `trigger_user_ids`: open_id list of users authorized to trigger sensitive
# scheduled jobs (e.g. memory audit). Get yours via Feishu API.
# `trigger_user_ids`: 被授权触发敏感定时任务的用户 open_id 列表。
# ---------------------------------------------------------------------------
[feishu]
app_id = "your-feishu-app-id-here"
app_secret = "your-feishu-app-secret-here"
domain = "feishu"
trigger_user_ids = [ "your-feishu-open-id-here" ]

# ---------------------------------------------------------------------------
# [[services]] — PM2-style long-running services launched by `remi serve`.
# 由 `remi serve` 启动的常驻服务(PM2 风格)。
# Use relative paths or `~` so the config is portable across machines.
# 推荐使用相对路径或 `~`,以便配置在不同机器间通用。
# ---------------------------------------------------------------------------
[[services]]
name = "remi-web"
script = "web/server.ts"
interpreter = "bun"
cwd = "."
build = "cd web/frontend && bun run build"
port = 6120

# ---------------------------------------------------------------------------
# [bot_menu] — Feishu bot menu definition.
# 飞书机器人菜单定义。
# Synced to Feishu via menu-sync on startup. Each top-level entry is a menu
# group; `children` are clickable items that send the configured message.
# 启动时通过 menu-sync 同步到飞书。每个顶层条目是一个菜单组；
# `children` 是点击后发送配置消息的子项。
# ---------------------------------------------------------------------------
[[bot_menu.default]]
name = "Commands"

[bot_menu.default.i18n_name]
en_us = "Commands"
zh_cn = "命令"

[bot_menu.default.icon]
token = "menu_outlined"
color = "green"

[[bot_menu.default.children]]
name = "/clear"

[[bot_menu.default.children.behaviors]]
type = "send_message"

[[bot_menu.default.children]]
name = "/status"

[[bot_menu.default.children.behaviors]]
type = "send_message"

