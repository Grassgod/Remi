# Remi Configuration
# Copy to remi.toml (or ~/.remi/remi.toml) and fill in your values.
# Priority: ./remi.toml > ~/.remi/remi.toml > defaults
# Never commit secrets (app_secret, api_key, etc.) to version control.

# ---------------------------------------------------------------------------
# [provider] — ACP agent configuration.
# Remi uses the Agent Client Protocol (ACP) to communicate with coding agents.
# Supported agents: claude (claude-agent-acp) and codex (codex-acp).
# Install: npm install -g @agentclientprotocol/claude-agent-acp
#          npm install -g @agentclientprotocol/codex-acp
# ---------------------------------------------------------------------------
[provider]
default = "claude"         # "claude" or "codex"

[provider.claude]
# executable = "claude-agent-acp"   # auto-detected if not specified
# model = "claude-opus-4-7"         # optional model override
timeout = 300

[provider.codex]
# executable = "codex-acp"          # auto-detected if not specified
timeout = 300

# ---------------------------------------------------------------------------
# [feishu] — Feishu/Lark bot connector.
# Create an app at https://open.feishu.cn (or https://open.larksuite.com).
# domain: "feishu" for China cloud, "lark" for international.
# trigger_user_ids: open_ids allowed to trigger admin-only operations.
# ---------------------------------------------------------------------------
[feishu]
app_id = "your-feishu-app-id"
app_secret = "your-feishu-app-secret"
domain = "feishu"
trigger_user_ids = []

# ---------------------------------------------------------------------------
# [[services]] — Long-running services started by `remi serve` via PM2.
# ---------------------------------------------------------------------------
[[services]]
name = "remi-web"
script = "web/server.ts"
interpreter = "bun"
cwd = "."
build = "cd web/frontend && bun run build"
port = 6120

# ---------------------------------------------------------------------------
# [bot_menu] — Feishu bot menu (synced on startup).
# ---------------------------------------------------------------------------
[[bot_menu.default]]
name = "Commands"

[bot_menu.default.i18n_name]
en_us = "Commands"
zh_cn = "命令"

[bot_menu.default.icon]
token = "menu_outlined"
color = "green"

[[bot_menu.default.children]]
name = "/clear"
[[bot_menu.default.children.behaviors]]
type = "send_message"

[[bot_menu.default.children]]
name = "/status"
[[bot_menu.default.children.behaviors]]
type = "send_message"

[[bot_menu.default.children]]
name = "/esc"
[[bot_menu.default.children.behaviors]]
type = "send_message"

[[bot_menu.default]]
name = "Switch"

[bot_menu.default.i18n_name]
en_us = "Switch"
zh_cn = "切换"

[bot_menu.default.icon]
token = "switch_outlined"
color = "blue"

[[bot_menu.default.children]]
name = "/switch claude:bypass"
[[bot_menu.default.children.behaviors]]
type = "send_message"

[[bot_menu.default.children]]
name = "/switch claude:plan"
[[bot_menu.default.children.behaviors]]
type = "send_message"

[[bot_menu.default.children]]
name = "/switch codex"
[[bot_menu.default.children.behaviors]]
type = "send_message"

# ---------------------------------------------------------------------------
# [proxy] — HTTP proxy for outbound requests (optional).
# ---------------------------------------------------------------------------
# [proxy]
# http = "http://127.0.0.1:7890"
# no_proxy = "localhost,127.0.0.1"

# ---------------------------------------------------------------------------
# [embedding] — Vector search embedding provider (optional).
# ---------------------------------------------------------------------------
# [embedding]
# provider = "voyage"
# api_key = "your-voyage-api-key"
# model = "voyage-3.5-lite"

# ---------------------------------------------------------------------------
# [google] — Gemini API for /image skill (optional).
# ---------------------------------------------------------------------------
# [google]
# api_key = "your-google-api-key"

# ---------------------------------------------------------------------------
# [tracing] — Request tracing config.
# ---------------------------------------------------------------------------
[tracing]
enabled = true

# ---------------------------------------------------------------------------
# [[cron.jobs]] — Scheduled jobs.
# handler: builtin:heartbeat | agent:<name> | skill:run | cli-ingest
# ---------------------------------------------------------------------------
[[cron.jobs]]
id = "builtin:heartbeat"
handler = "builtin:heartbeat"
every = "300s"

[[cron.jobs]]
id = "agent:memory-audit"
handler = "agent:memory-audit"
cron = "0 3 * * *"
[cron.jobs.handler_config]
connectorName = "feishu"
pushTargets = []

# ---------------------------------------------------------------------------
# SSO web login (inbound) — managed by the SSO plugin in DB, NOT in remi.toml.
#
# To bootstrap on first run, you can drop the following block here; on first
# boot the SSO plugin reads it, copies it into the `sso_providers` table, and
# from then on ignores it. After the first successful boot you may safely
# delete this section.
#
# [sso]
# issuer = "https://sso.bytedance.com"
# client_id = "..."
# client_secret = "..."
#
# Callback URL is auto-derived from the request Host header, so no
# `base_url` config is needed. The redirect URI registered in SSO must be:
#   http://<your-host>:<port>/api/auth/sso/bytedance/callback
#
# Use GET /api/v1/system/host-info to see this server's detected IPs/hostname.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Clusters — runtime environments — managed in DB (table `clusters`), NOT here.
# Same one-time seed pattern as [sso] above: [[clusters]] entries here get
# migrated to DB on first boot, then this block is ignored.
#
# [[clusters]]
# id = "dev"
# name = "Dev"
# hostname = "..."
# port = 6120
# protocol = "http"
# is_default = false
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# [auth] — Bootstrap admin list.
# Emails in admin_emails will be auto-promoted to admin on first login.
# After first login, role is stored in DB (users.role); changes via DB / admin UI.
# ---------------------------------------------------------------------------
# [auth]
# admin_emails = ["you@example.com"]
